{
  "name": "@qlik/dts-bundler",
  "version": "",
  "description": "Bundle TypeScript declaration files into a single file",
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qlik-oss/dts-bundler.git"
  },
  "license": "ISC",
  "author": "nilzona",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bundle-types": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --outDir dist --format esm --dts",
    "check-types": "tsc --noEmit",
    "format:check": "prettier --check '**' --ignore-unknown",
    "format:write": "prettier --write '**' --ignore-unknown",
    "lint": "eslint .",
    "test": "vitest run",
    "test:update": "vitest run -u",
    "test:watch": "vitest"
  },
  "prettier": "@qlik/prettier-config",
  "dependencies": {
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@qlik/eslint-config": "2.0.0-next.1",
    "@qlik/prettier-config": "^0.4.36",
    "@qlik/tsconfig": "^0.3.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.7",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "updateConfig": {
      "ignoreDependencies": [
        "eslint"
      ]
    }
  }
}
